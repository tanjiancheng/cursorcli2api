# ===== Gateway =====
CODEX_GATEWAY_HOST=0.0.0.0
CODEX_GATEWAY_PORT=8000
CODEX_GATEWAY_TOKEN=sk-your-gateway-token    # Bearer token auth (empty = no auth)

# ===== Provider =====
CODEX_PROVIDER=cursor-agent                  # auto | codex | cursor-agent | claude | gemini
CODEX_PRESET=cursor-auto                     # cursor-fast | cursor-auto | codex-fast | claude-oauth | gemini-cloudcode
# CODEX_MODEL=gpt-5.2                        # Default model when client doesn't specify

# ===== Cursor Agent =====
CURSOR_AGENT_BIN=cursor-agent
CURSOR_AGENT_WORKSPACE=/tmp/cursor-empty-workspace
# CURSOR_AGENT_API_KEY=                      # or use `cursor-agent login`
CURSOR_AGENT_MODEL=auto
CURSOR_AGENT_STREAM_PARTIAL_OUTPUT=true
CURSOR_AGENT_DISABLE_INDEXING=true
# CURSOR_AGENT_EXTRA_ARGS=                   # extra CLI flags, shell-quoted

# ===== Claude =====
# CLAUDE_BIN=claude
# CLAUDE_MODEL=sonnet
# CLAUDE_USE_OAUTH_API=false

# ===== Gemini =====
# GEMINI_BIN=gemini
# GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_USE_CLOUDCODE_API=false

# ===== Models =====
CODEX_ADVERTISED_MODELS=auto,composer-2.5-fast
CODEX_ALLOW_CLIENT_MODEL_OVERRIDE=true
# CODEX_ALLOW_CLIENT_PROVIDER_OVERRIDE=false

# ===== Limits =====
CODEX_MAX_CONCURRENCY=100
CODEX_TIMEOUT_SECONDS=600
CODEX_MAX_PROMPT_CHARS=200000
CODEX_SSE_KEEPALIVE_SECONDS=2

# ===== Logging =====
CODEX_LOG_MODE=summary                       # summary | qa
CODEX_LOG_MAX_CHARS=4000
CODEX_LOG_EVENTS=true
# CODEX_DEBUG_LOG=false
